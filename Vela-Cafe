async function loadExpenses2() {
  const rows = await fetchSheet('ລາຍລະອຽດລາຍຈ່າຍ');
  if (rows.length < 2) return;

  // Find column indexes from header row
  const hdr = rows[0].map(h => String(h||'').trim());
  const col = {
    date:  hdr.findIndex(h => h.includes('ວັນທີ')),
    desc:  hdr.findIndex(h => h.includes('ລາຍລະອຽດ') || h.includes('ລາຍລະຍັດ')),
    cat:   hdr.findIndex(h => h.includes('ປະເພດ')),
    qty:   hdr.findIndex(h => h.includes('ຈຳນວນ')),
    price: hdr.findIndex(h => h.includes('ລາຄາ')),
    cur:   hdr.findIndex(h => h.includes('ສະກຸນ')),
    lak:   hdr.findIndex(h => h.includes('ກີບ') || h.includes('ເງິນກີບ')),
  };
  // fallback to known positions if headers not found
  if(col.date  < 0) col.date  = 0;
  if(col.desc  < 0) col.desc  = 1;
  if(col.cat   < 0) col.cat   = 2;
  if(col.qty   < 0) col.qty   = 3;
  if(col.price < 0) col.price = 4;
  if(col.cur   < 0) col.cur   = 6;
  if(col.lak   < 0) col.lak   = rows[0].length - 1; // last column

  const data = rows.slice(1).filter(r => r[col.date] && r[col.date] !== 'NaT' && r[col.desc]);
  const tbody = document.getElementById('expTable');
  let total = 0;
  tbody.innerHTML = data.map((r, i) => {
    const lak = parseFloat(String(r[col.lak]||'0').replace(/,/g,'')) || 0;
    total += lak;
    const id = 'exp-gs-' + i;
    return `<tr><td>${fmtDate(r[col.date])}</td><td>${r[col.desc]||'—'}</td><td><span class="badge ${getBadge(r[col.cat])}">${r[col.cat]||'—'}</span></td><td class="mono text-right">${fmt(r[col.qty])}</td><td class="mono text-right">${fmt(r[col.price])}</td><td>${r[col.cur]||'—'}</td><td class="mono text-right amount-neg">${fmt(lak)}</td><td>${slipBtn(id, r[col.desc]||'', fmt(lak)+' LAK')}</td></tr>`;
  }).join('');
  document.getElementById('expCount').textContent = data.length + ' ລາຍການ';
  document.getElementById('em-total').textContent = fmt(total);
  document.getElementById('m-totalExp').textContent = fmt(total);

  const recent = data.slice(-5).reverse();
  document.getElementById('recentExpTbl').innerHTML = recent.map((r,i) => {
    const lak = parseFloat(String(r[col.lak]||0).replace(/,/g,'')) || 0;
    const id = 'exp-gs-recent-' + i;
    return `<tr><td>${fmtDate(r[col.date])}</td><td>${(r[col.desc]||'—').substring(0,28)}</td><td class="mono text-right amount-neg">${fmt(lak)}</td><td>${slipBtn(id, r[col.desc]||'', fmt(lak)+' LAK')}</td></tr>`;
  }).join('');

  const cats = {};
  data.forEach(r => { const c = r[col.cat]||'ອື່ນໆ'; const l = parseFloat(String(r[col.lak]||0).replace(/,/g,''))||0; cats[c]=(cats[c]||0)+l; });
  const maxV = Math.max(...Object.values(cats));
  const colors = ['#c8a96e','#3ecfb0','#5a9be0','#e05a5a','#9b5ae0'];
  document.getElementById('expenseChart').innerHTML = Object.entries(cats).sort((a,b)=>b[1]-a[1]).map(([k,v],i)=>`
    <div class="bar-row"><div class="bar-label" title="${k}">${k}</div><div class="bar-track"><div class="bar-fill" style="width:${(v/maxV*100).toFixed(1)}%;background:${colors[i%colors.length]}"></div></div><div class="bar-amount">${(v/1e6).toFixed(2)}M</div></div>`).join('');

  // Build category cards + filter buttons (all categories)
  const catColors = ['#c8a96e','#3ecfb0','#5a9be0','#e05a5a','#9b5ae0','#5ae07a','#e0a05a'];
  const sorted = Object.entries(cats).sort((a,b) => b[1]-a[1]);

  // Category metric cards
  document.getElementById('expCatCards').innerHTML = sorted.map(([cat, val], i) => `
    <div class="metric-card" data-expcat="${i}" style="border-top:2px solid ${catColors[i%catColors.length]};cursor:pointer;">
      <div class="metric-label" style="font-size:10px">${cat}</div>
      <div class="metric-value" style="font-size:16px">${fmt(val)}</div>
      <div class="metric-sub">LAK · ກົດເພື່ອຟິວເຕີ້</div>
    </div>`).join('');
  document.querySelectorAll('[data-expcat]').forEach(el => {
    const idx = parseInt(el.dataset.expcat);
    el.addEventListener('click', () => filterExpenses(sorted[idx][0]));
  });

  // Filter buttons
  const filterContainer = document.getElementById('expFilterBtns');
  filterContainer.innerHTML = `<button class="exp-filter-btn active" data-cat="ທັງໝົດ"
    style="background:var(--accent);color:#0f0f11;border:none;border-radius:20px;padding:4px 14px;font-family:'Noto Sans Lao',sans-serif;font-size:12px;font-weight:600;cursor:pointer;">ທັງໝົດ</button>
  ` + sorted.map(([cat], i) => `
    <button class="exp-filter-btn" data-cat="${i}"
      style="background:var(--bg3);color:var(--text2);border:.5px solid var(--border2);border-radius:20px;padding:4px 14px;font-family:'Noto Sans Lao',sans-serif;font-size:12px;cursor:pointer;">
      ${cat}
    </button>`).join('');
  filterContainer.querySelectorAll('[data-cat]').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;
      filterExpenses(isNaN(cat) ? cat : sorted[parseInt(cat)][0]);
    });
  });

  // Store full data for filtering
  window._expAllData = data;
  window._expCol = col;
}

