function applyUserRole() {
  const isAdmin = currentUser && currentUser.role === 'admin';
  document.querySelectorAll('.admin-only').forEach(el => el.style.display = isAdmin ? '' : 'none');
  document.getElementById('navUsers').style.display = isAdmin ? '' : 'none';
  // viewer: hide upload/edit buttons
  if(!isAdmin) {
    document.querySelectorAll('.slip-btn, .btn-load, .gs-btn').forEach(el => {
      if(!el.id || el.id !== 'loadBtn') {} // keep load btn but restrict later if needed
