// ========== STOCK PRODUCT IMAGES ==========
const STOCK_IMG_KEY = 'velacafe_stock_imgs_v1';
// stockImgs = { [itemKey]: { dataUrl?, gsUrl?, name } }
let stockImgs = {};
let stockData = []; // current stock rows
let currentProdKey = '';
let stockViewMode = 'grid';

function saveStockImgs() {
  try { localStorage.setItem(STOCK_IMG_KEY, JSON.stringify(stockImgs)); } catch(e) {}
}
function loadStockImgs() {
  try { const d = localStorage.getItem(STOCK_IMG_KEY); if(d) stockImgs = JSON.parse(d); } catch(e) {}
}

function setStockView(mode) {
  stockViewMode = mode;
  document.getElementById('btnGrid').classList.toggle('active', mode==='grid');
  document.getElementById('btnList').classList.toggle('active', mode==='list');
  document.getElementById('stockGridView').style.display = mode==='grid' ? 'grid' : 'none';
  document.getElementById('stockListView').style.display = mode==='list' ? 'block' : 'none';
}

function getBadge2(cat) {
  if(!cat) return 'badge-blue';
  if(cat.includes('ອຸປ')) return 'badge-teal';
  return 'badge-blue';
}

function renderStockGrid() {
  const grid = document.getElementById('stockGridView');
  const listBody = document.getElementById('stockListBody');
  if(!stockData.length) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:3rem;color:var(--text2)">ໂຫລດ Google Sheets ເພື່ອສະແດງສະຕັອກ</div>';
    listBody.innerHTML = '';
    return;
  }
  const cards = stockData.map((item, i) => {
    const key = 'stock-' + i;
    const img = stockImgs[key];
    const imgSrc = img ? (img.gsUrl || img.dataUrl) : null;
    const imgEl = imgSrc
      ? `<img class="prod-img" src="${imgSrc}" alt="${item.name}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/><div class="prod-img-placeholder" style="display:none"><span>📦</span><small>ໂຫລດຮູບບໍ່ໄດ້</small></div>`
      : `<div class="prod-img-placeholder"><span>📦</span><small>ກົດເພື່ອເພີ່ມຮູບ</small></div>`;
    const hasBadge = imgSrc ? `<div class="prod-img-badge">📷 ມີຮູບ</div>` : '';
    return `<div class="prod-card" onclick="openProdImgModal('${key}','${item.name}','${item.cat}','${item.price} ${item.currency}')">
      <div class="prod-img-wrap">
        ${imgEl}
        ${hasBadge}
        <div class="prod-edit-overlay"><div class="prod-edit-icon">📷</div></div>
      </div>
      <div class="prod-body">
        <div class="prod-name">${item.name}</div>
        <div class="prod-cat"><span class="badge ${getBadge2(item.cat)}">${item.cat||'—'}</span></div>
        <div class="prod-meta">
          <span class="prod-price">${item.price} ${item.currency}</span>
          <span class="prod-qty">${item.qty} ${item.unit}</span>
        </div>
        ${item.size ? `<div style="font-size:11px;color:var(--text2);margin-top:4px">${item.size}</div>` : ''}
      </div>
    </div>`;
  }).join('');
  grid.innerHTML = cards;

  // list view
  listBody.innerHTML = stockData.map((item, i) => {
    const key = 'stock-' + i;
    const img = stockImgs[key];
    const imgSrc = img ? (img.gsUrl || img.dataUrl) : null;
    const thumb = imgSrc
      ? `<img class="list-thumb" src="${imgSrc}" alt="${item.name}" onclick="openProdImgModal('${key}','${item.name}','${item.cat}','${item.price} ${item.currency}')" onerror="this.outerHTML='<div class=list-thumb-placeholder onclick=openProdImgModal(\'${key}\',\'${item.name}\',\'${item.cat}\',\'${item.price} ${item.currency}\')>📦</div>'">`
      : `<div class="list-thumb-placeholder" onclick="openProdImgModal('${key}','${item.name}','${item.cat}','${item.price} ${item.currency}')">📦</div>`;
    return `<tr>
      <td>${thumb}</td>
      <td class="mono">${i+1}</td>
      <td style="font-weight:500">${item.name}</td>
      <td><span class="badge ${getBadge2(item.cat)}">${item.cat||'—'}</span></td>
      <td class="mono text-right">${item.price}</td>
      <td>${item.currency}</td>
      <td class="mono text-right">${item.qty}</td>
      <td>${item.unit}</td>
      <td style="font-size:12px;color:var(--text2)">${item.size||'—'}</td>
    </tr>`;
  }).join('');
}

function openProdImgModal(key, name, cat, priceStr) {
  currentProdKey = key;
  document.getElementById('prodModalTitle').textContent = '📷 ' + name;
  document.getElementById('prodModalInfo').textContent = cat + ' — ' + priceStr;
  const img = stockImgs[key];
  const src = img ? (img.gsUrl || img.dataUrl) : null;
  const prevWrap = document.getElementById('prodCurrentImg');
  if(src) {
    document.getElementById('prodImgPreview').src = src;
    prevWrap.style.display = 'block';
  } else {
    prevWrap.style.display = 'none';
  }
  document.getElementById('prodUrlInput').value = (img && img.gsUrl) ? img.gsUrl : '';
  document.getElementById('productImgModal').classList.add('open');
}
function closeProdModal() { document.getElementById('productImgModal').classList.remove('open'); }
function closeProdModalOutside(e) { if(e.target===document.getElementById('productImgModal')) closeProdModal(); }

function triggerProdUpload() { document.getElementById('prodFileInput').click(); }
function handleProdFile(e) {
  const file = e.target.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    if(!stockImgs[currentProdKey]) stockImgs[currentProdKey] = {};
    stockImgs[currentProdKey].dataUrl = ev.target.result;
    stockImgs[currentProdKey].gsUrl = null; // local overrides gs
    saveStockImgs();
    document.getElementById('prodImgPreview').src = ev.target.result;
    document.getElementById('prodCurrentImg').style.display = 'block';
    renderStockGrid();
  };
  reader.readAsDataURL(file);
  e.target.value = '';
}

function saveProdUrl() {
  const url = document.getElementById('prodUrlInput').value.trim();
  if(!url) { alert('ກະລຸນາໃສ່ URL ຮູບ'); return; }
  // convert Google Drive share URL to direct
  let finalUrl = url;
  const driveMatch = url ? url.match(/\/d\/([a-zA-Z0-9_-]+)/) : null;
  if(driveMatch) {
    // Use Apps Script proxy to bypass CORS
    const fileId = driveMatch[1];
    const baseUrl = appsScriptUrl || window.location.href.split('?')[0];
    finalUrl = baseUrl + '?imgid=' + fileId;
    // Fetch base64 from proxy then store
    fetch(finalUrl).then(r=>r.json()).then(d=>{
      if(d.img){
        if(!stockImgs[currentProdKey]) stockImgs[currentProdKey]={};
        stockImgs[currentProdKey].gsUrl = d.img;
        stockImgs[currentProdKey].dataUrl = null;
        saveStockImgs();
        document.getElementById('prodImgPreview').src = d.img;
        document.getElementById('prodCurrentImg').style.display='block';
        renderStockGrid();
        alert('✅ ໂຫລດຮູບສຳເລັດ!');
      } else {
        alert('ໂຫລດຮູບບໍ່ໄດ້: ' + (d.error||'unknown'));
      }
    }).catch(err=>alert('Error: '+err));
    btn.disabled=false; btn.textContent='ບັນທຶກ';
    return;
  }
  if(!stockImgs[currentProdKey]) stockImgs[currentProdKey] = {};
  stockImgs[currentProdKey].gsUrl = finalUrl;
  stockImgs[currentProdKey].dataUrl = null;
  saveStockImgs();
  document.getElementById('prodImgPreview').src = finalUrl;
  document.getElementById('prodCurrentImg').style.display = 'block';
  renderStockGrid();
  alert('ບັນທຶກ URL ສຳເລັດ!');
}

function deleteProdImg() {
  if(!confirm('ລຶບຮູບສິນຄ້ານີ້?')) return;
  delete stockImgs[currentProdKey];
  saveStockImgs();
  document.getElementById('prodCurrentImg').style.display = 'none';
  document.getElementById('prodUrlInput').value = '';
  renderStockGrid();
}

// ---- integrate with GS stock loader ----
async function loadStock2() {
  const rows = await fetchSheet('ສະຕັອກ');
  if(rows.length < 2) return;
  const header = rows[0].map(h => String(h||'').trim());
  const imgColIdx = header.findIndex(h => h.includes('ຮູບ') || h.toLowerCase().includes('image') || h.toLowerCase().includes('url'));
  const data = rows.slice(1).filter(r => r[0] && r[1]);
  stockData = data.map((r, i) => ({
    name: r[1]||'—', cat: r[3]||r[2]||'', price: r[4]||'—', currency: r[5]||'',
    qty: r[6]||'0', unit: r[7]||'', size: r[8]||'',
    gsImgUrl: imgColIdx >= 0 ? (r[imgColIdx]||'') : ''
  }));
  // auto-apply GS image URLs
  stockData.forEach((item, i) => {
    if(item.gsImgUrl) {
      let url = item.gsImgUrl;
      const driveMatch = url ? url.match(/\/d\/([a-zA-Z0-9_-]+)/) : null;
      if(driveMatch) {
        const fileId = driveMatch[1];
        const baseUrl2 = appsScriptUrl || window.location.href.split('?')[0];
        const proxyUrl = baseUrl2 + '?imgid=' + fileId;
        (function(key, pUrl){
          fetch(pUrl).then(r=>r.json()).then(d=>{
            if(d.img){
              if(!stockImgs[key]) stockImgs[key]={};
              stockImgs[key].gsUrl = d.img;
              saveStockImgs();
              renderStockGrid();
            }
          }).catch(()=>{});
        })('stock-'+i, proxyUrl);
        return; // use return instead of continue inside forEach
      }
      if(!stockImgs['stock-'+i]) stockImgs['stock-'+i] = {};
      // only set gsUrl; don't overwrite manual dataUrl upload
      stockImgs['stock-'+i].gsUrl = url;
    }
  });
  saveStockImgs();
  document.getElementById('stockCount').textContent = data.length + ' ລາຍການ';
  renderStockGrid();
}

