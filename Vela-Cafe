function updateTopbarUser() {
  if(!currentUser) return;
  const [bg, fg] = currentUser.color.split(',');
  const initials = currentUser.name.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
  const av = document.getElementById('topUserAvatar');
  av.style.background = bg; av.style.color = fg; av.textContent = initials;
  document.getElementById('topUserName').textContent = currentUser.name;
  const rt = document.getElementById('topUserRole');
  rt.textContent = currentUser.role === 'admin' ? '👑 Admin' : '👁 Viewer';
  rt.className = 'user-role-tag ' + (currentUser.role==='admin'?'role-admin':'role-viewer');
