// ---- Change Password ----
function openChangePwd() {
  closeUserMenu();
  ['cp-old','cp-new','cp-confirm'].forEach(id => document.getElementById(id).value='');
  document.getElementById('chpwdErr').style.display='none';
  document.getElementById('chpwdModal').classList.add('open');
}
function doChangePwd() {
  const oldP = document.getElementById('cp-old').value;
  const newP = document.getElementById('cp-new').value;
  const conf = document.getElementById('cp-confirm').value;
  const err = document.getElementById('chpwdErr');
  err.style.display='none';
  if(hashPwd(oldP) !== currentUser.pwdHash){ err.textContent='❌ Password ເກົ່າບໍ່ຖືກ'; err.style.display='block'; return; }
  if(newP.length < 6){ err.textContent='❌ Password ໃໝ່ຕ້ອງຢ່າງໜ້ອຍ 6 ຕົວ'; err.style.display='block'; return; }
  if(newP !== conf){ err.textContent='❌ ຢືນຢັນ Password ບໍ່ຕົງກັນ'; err.style.display='block'; return; }
  const users = loadUsers();
  const idx = users.findIndex(x=>x.username===currentUser.username);
  users[idx].pwdHash = hashPwd(newP);
  currentUser.pwdHash = hashPwd(newP);
  saveUsers(users);
  document.getElementById('chpwdModal').classList.remove('open');
  alert('✅ ປ່ຽນ Password ສຳເລັດ!');
}

