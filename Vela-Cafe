  try { localStorage.setItem(STORE_KEY, JSON.stringify(slips)); } catch(e) { console.warn('Storage full'); }
}
function loadSlipsFromStorage() {
  try {
    const d = localStorage.getItem(STORE_KEY);
    if (d) slips = JSON.parse(d);
  } catch(e) { slips = {}; }
  refreshAllUI();
}

// ========== TAB ==========
function switchTab(name) {
  const names = ['summary','assets','expenses','income','cny','stock','invest','slips','users'];
  document.querySelectorAll('.nav-tab').forEach((t,i) => t.classList.toggle('active', names[i] === name));
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  const sec = document.getElementById('tab-' + name);
  if(sec) sec.classList.add('active');
  if(name === 'slips') renderAllSlipsGrid();
  if(name === 'users') renderUserMgmt();
}

// ========== MODAL ==========
function openSlipModal(txnId, label, amount) {
  currentModalId = txnId;
  currentModalLabel = label;
  currentModalAmount = amount;
  document.getElementById('modalTitle').textContent = '🧾 ສະລິບ — ' + label;
  document.getElementById('modalRef').textContent = '💰 ' + amount;
  document.getElementById('slipModal').classList.add('open');
  renderSlipGrid();
}
function closeSlipModal() {
  document.getElementById('slipModal').classList.remove('open');
}
function closeModalOutside(e) {
  if (e.target === document.getElementById('slipModal')) closeSlipModal();
}

// ========== UPLOAD ==========
function triggerUpload() { document.getElementById('fileInput').click(); }

const uploadZone = document.getElementById('uploadZone');
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault(); uploadZone.classList.remove('drag');
  handleFileList(e.dataTransfer.files);
});

function handleFiles(e) { handleFileList(e.target.files); e.target.value = ''; }

function handleFileList(files) {
  if (!files.length) return;
  Array.from(files).forEach(file => {
    const reader = new FileReader();
    reader.onload = ev => {
      if (!slips[currentModalId]) slips[currentModalId] = [];
      slips[currentModalId].push({ name: file.name, dataUrl: ev.target.result, date: new Date().toLocaleDateString('lo-LA'), label: currentModalLabel, amount: currentModalAmount });
      saveSlips();
      renderSlipGrid();
      refreshAllUI();
    };
    reader.readAsDataURL(file);
  });
}

// ========== RENDER GRID (modal) ==========
function renderSlipGrid() {
  const grid = document.getElementById('slipGrid');
  const items = slips[currentModalId] || [];
  if (!items.length) { grid.innerHTML = ''; return; }
  grid.innerHTML = items.map((s,i) => `
    <div class="slip-thumb" onclick="openLightbox('${currentModalId}',${i})">
      <img src="${s.dataUrl}" alt="${s.name}" loading="lazy"/>
      <button class="slip-thumb-del" onclick="deleteSlip(event,'${currentModalId}',${i})">✕</button>
      <div class="slip-thumb-label">${s.name}</div>
    </div>`).join('');
}

// ========== DELETE ==========
function deleteSlip(e, txnId, idx) {
  e.stopPropagation();
  if (!confirm('ລຶບຮູບນີ້?')) return;
  slips[txnId].splice(idx, 1);
  if (!slips[txnId].length) delete slips[txnId];
  saveSlips();
  renderSlipGrid();
  refreshAllUI();
}

// ========== LIGHTBOX ==========
function openLightbox(txnId, idx) {
  const s = slips[txnId][idx];
  document.getElementById('lightboxImg').src = s.dataUrl;
  document.getElementById('lightboxCaption').textContent = s.name + ' — ' + s.date;
  document.getElementById('lightbox').classList.add('open');
}
function closeLightbox() { document.getElementById('lightbox').classList.remove('open'); }

// ========== REFRESH UI ==========
function refreshAllUI() {
  let total = 0;
  Object.values(slips).forEach(arr => total += arr.length);

  // nav badge
  document.getElementById('navSlipCount').textContent = total;
  document.getElementById('m-slips').textContent = total;
  document.getElementById('slipTabSub').textContent = total + ' ໄຟລ໌ຮູບທັງໝົດ';

  // update all slip buttons
  document.querySelectorAll('[id^="sc-"]').forEach(el => {
    const btnId = el.id.replace('sc-', '');
    const count = (slips[btnId] || []).length;
    el.textContent = count > 0 ? count + ' ຮູບ' : '+';
    el.style.color = count > 0 ? 'var(--teal)' : '';
  });
}

// ========== ALL SLIPS GRID ==========
function renderAllSlipsGrid(filter) {
  const grid = document.getElementById('allSlipsGrid');
  let allItems = [];
  Object.entries(slips).forEach(([txnId, arr]) => {
    arr.forEach((s, idx) => allItems.push({ txnId, idx, ...s }));
  });
  if (filter) {
    const q = filter.toLowerCase();
    allItems = allItems.filter(s => s.label.toLowerCase().includes(q) || s.name.toLowerCase().includes(q) || s.amount.toLowerCase().includes(q));
  }
  if (!allItems.length) {
    grid.innerHTML = `<div class="slip-empty"><div class="slip-empty-icon">🧾</div><div>${filter ? 'ບໍ່ພົບຜົນການຄົ້ນຫາ' : 'ຍັງບໍ່ມີສະລິບ'}</div><div style="font-size:12px;margin-top:.5rem">ກົດປຸ່ມ 📎 ໃນຕາຕະລາງ ເພື່ອເພີ່ມຮູບ</div></div>`;
    return;
  }
  grid.innerHTML = allItems.map(s => `
    <div class="slip-card" onclick="openLightboxDirect('${s.dataUrl}','${s.name}','${s.date}')">
      <img class="slip-card-img" src="${s.dataUrl}" alt="${s.name}" loading="lazy"/>
      <div class="slip-card-body">
        <div class="slip-card-ref">${s.label}</div>
        <div class="slip-card-date">${s.date}</div>
        <div class="slip-card-amount">${s.amount}</div>
      </div>
    </div>`).join('');
}

function openLightboxDirect(dataUrl, name, date) {
  document.getElementById('lightboxImg').src = dataUrl;
  document.getElementById('lightboxCaption').textContent = name + ' — ' + date;
  document.getElementById('lightbox').classList.add('open');
}

function filterSlips(val) { renderAllSlipsGrid(val); }

// ========== GOOGLE SHEETS via APPS SCRIPT ==========
let appsScriptUrl = '';
const GS_URL_KEY = 'velacafe_gsurl';

function toggleSetup() {
  const p = document.getElementById('setupPanel');
  p.style.display = p.style.display === 'none' ? '' : 'none';
}
function copyAppsCode() {
  const code = document.getElementById('appsScriptCode').textContent;
  navigator.clipboard.writeText(code).then(() => {
    const el = document.querySelector('#appsScriptCode + div');
    if(el){ el.textContent = '✅ ຄັດລອກແລ້ວ!'; setTimeout(()=>{ el.textContent='📋 ກົດທີ່ code ເພື່ອຄັດລອກ'; }, 2000); }
  }).catch(() => { alert('ກົດ Ctrl+A ໃນ code box ແລ້ວ Ctrl+C'); });
}

function openSheet() {
  // open from stored URL — derive spreadsheet link if possible
  if(appsScriptUrl) window.open('https://docs.google.com/spreadsheets', '_blank');
}

async function fetchSheet(name) {
  // When served from Apps Script, use same URL with sheet param
  const baseUrl = appsScriptUrl || window.location.href.split('?')[0];
  const url = baseUrl + '?sheet=' + encodeURIComponent(name);
  const r = await fetch(url);
  if(!r.ok) throw new Error('ດຶງຂໍ້ມູນບໍ່ໄດ້: HTTP ' + r.status);
  const json = await r.json();
  if(json.error) throw new Error('Sheet error: ' + json.error);
  return json.data || [];
}

async function saveUrlAndLoad() {
  const url = document.getElementById('appsScriptUrl').value.trim();
  if(!url) { alert('ກະລຸນາວາງ Apps Script URL ກ່ອນ'); return; }
  if(!url || !url.includes('script.google.com')) { alert('URL ບໍ່ຖືກ — ຕ້ອງເລີ່ມດ້ວຍ https://script.google.com/macros/s/...'); return; }
  appsScriptUrl = url;
  try { localStorage.setItem(GS_URL_KEY, url); } catch(e) {}
  document.getElementById('urlStatus').textContent = '✅ ບັນທຶກແລ້ວ';
  await loadAllData();
  document.getElementById('setupPanel').style.display = 'none';
}

async function loadAllData() {
  const btn = document.getElementById('loadBtn');
  btn.disabled = true; btn.textContent = '⏳ ກຳລັງໂຫລດ...';
  try {
    await Promise.all([loadExpenses2(), loadIncome2(), loadStock2(), loadCNY2()]);
    document.getElementById('updateTime').textContent = 'ອັບເດດ: ' + new Date().toLocaleTimeString('lo-LA');
    refreshAllUI();
  } catch(e) {
    console.error(e);
    document.getElementById('setupPanel').style.display = '';
    alert('ໂຫລດບໍ່ໄດ້: ' + e.message);
  }
  btn.disabled = false; btn.textContent = '⚡ ເຊື່ອມ & ບັນທຶກ';
}

function fmt(n) { if(!n && n!==0) return '—'; const num = parseFloat(String(n).replace(/,/g,'')); return isNaN(num) ? n : num.toLocaleString('en-US'); }
function fmtDate(d) { if(!d) return '—'; const s = String(d); if(s.includes('-')){ const p=s.split('-'); return `${p[2].substring(0,2)}/${p[1]}/${p[0]}`; } if(s.includes('/')){ return s; } return s; }
function getBadge(cat) { if(!cat) return 'badge-blue'; if(cat.includes('ມັດ')) return 'badge-gold'; if(cat.includes('ໂປ')||cat.includes('ແກ')) return 'badge-purple'; if(cat.includes('ຮ້ານ')) return 'badge-blue'; return 'badge-teal'; }
function slipBtn(id, label, amount) {
  return `<button class="slip-btn" onclick="openSlipModal('${id}','${label}','${amount}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg><span id="sc-${id}">+</span></button>`;
}

// ===== EXPENSE FILTER =====
function filterExpenses(cat) {
  const data = window._expAllData || [];
  const col = window._expCol || {date:0,desc:1,cat:2,qty:3,price:4,cur:6,lak:10};

  // Update active filter button style
  document.querySelectorAll('.exp-filter-btn').forEach(btn => {
    const isActive = btn.dataset.cat === cat;
    btn.style.background = isActive ? 'var(--accent)' : 'var(--bg3)';
    btn.style.color = isActive ? '#0f0f11' : 'var(--text2)';
    btn.style.border = isActive ? 'none' : '.5px solid var(--border2)';
    btn.style.fontWeight = isActive ? '600' : '400';
  });

  const filtered = cat === 'ທັງໝົດ' ? data : data.filter(r => (r[col.cat]||'') === cat);
  const tbody = document.getElementById('expTable');

  if(!filtered.length) {
    tbody.innerHTML = `<tr><td colspan="8" class="no-data">ບໍ່ມີລາຍການໃນໝວດ "${cat}"</td></tr>`;
    document.getElementById('expCount').textContent = '0 ລາຍການ';
    document.getElementById('expTableTitle').textContent = cat === 'ທັງໝົດ' ? 'ລາຍຈ່າຍທັງໝົດ' : 'ໝວດ: ' + cat;
    return;
  }

  tbody.innerHTML = filtered.map((r, i) => {
    const lak = parseFloat(String(r[col.lak]||'0').replace(/,/g,'')) || 0;
    const id = 'exp-f-' + i;
    return `<tr><td>${fmtDate(r[col.date])}</td><td>${r[col.desc]||'—'}</td><td><span class="badge ${getBadge(r[col.cat])}">${r[col.cat]||'—'}</span></td><td class="mono text-right">${fmt(r[col.qty])}</td><td class="mono text-right">${fmt(r[col.price])}</td><td>${r[col.cur]||'—'}</td><td class="mono text-right amount-neg">${fmt(lak)}</td><td>${slipBtn(id, r[col.desc]||'', fmt(lak)+' LAK')}</td></tr>`;
  }).join('');

  const subtotal = filtered.reduce((s,r) => s + (parseFloat(String(r[col.lak]||0).replace(/,/g,''))||0), 0);
  document.getElementById('expCount').textContent = filtered.length + ' ລາຍການ' + (cat !== 'ທັງໝົດ' ? ' · ' + fmt(subtotal) + ' LAK' : '');
  document.getElementById('expTableTitle').textContent = cat === 'ທັງໝົດ' ? 'ລາຍຈ່າຍທັງໝົດ' : 'ໝວດ: ' + cat;
  refreshAllUI();
}

