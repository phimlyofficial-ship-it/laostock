  grid.innerHTML = users.map((u, i) => {
    const [bg, fg] = u.color.split(',');
    const initials = u.name.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
    const isSelf = currentUser && u.username === currentUser.username;
    return `<div class="user-card">
      <div class="uc-top">
        <div class="uc-avatar" style="background:${bg};color:${fg}">${initials}</div>
        <div class="uc-info">
          <div class="uc-name">${u.name} ${isSelf?'<span style="font-size:10px;color:var(--text2)">(ຂ້ອຍ)</span>':''}</div>
          <div class="uc-username">@${u.username}</div>
        </div>
        <span class="user-role-tag ${u.role==='admin'?'role-admin':'role-viewer'}">${u.role==='admin'?'👑 Admin':'👁 Viewer'}</span>
      </div>
      <div class="uc-row"><span style="color:var(--text2)">ວັນທີສ້າງ</span><span>${u.created||'—'}</span></div>
      <div class="uc-row"><span style="color:var(--text2)">ສິດ</span><span>${u.role==='admin'?'ແກ້ໄຂໄດ້ທຸກຢ່າງ':'ເບິ່ງໄດ້ຢ່າງດຽວ'}</span></div>
      <div class="uc-actions">
        <button class="uc-btn uc-btn-edit" onclick="openEditUser(${i})">✏️ ແກ້ໄຂ</button>
        ${!isSelf ? `<button class="uc-btn uc-btn-del" onclick="deleteUser(${i})">🗑 ລຶບ</button>` : '<button class="uc-btn" style="opacity:.3;cursor:default" disabled>🗑 ລຶບ</button>'}
      </div>
    </div>`;
  }).join('');
}

function addUser() {
  const name = document.getElementById('nu-name').value.trim();
  const user = document.getElementById('nu-user').value.trim().toLowerCase();
  const pass = document.getElementById('nu-pass').value;
  const role = document.getElementById('nu-role').value;
  const color = document.getElementById('nu-color').value;
  if(!name||!user||!pass){ alert('ກະລຸນາໃສ່ຂໍ້ມູນໃຫ້ຄົບ'); return; }
  if(pass.length<6){ alert('Password ຕ້ອງຢ່າງໜ້ອຍ 6 ຕົວ'); return; }
  const users = loadUsers();
  if(users.find(x=>x.username===user)){ alert('Username ນີ້ຖືກໃຊ້ແລ້ວ'); return; }
  users.push({ name, username:user, pwdHash:hashPwd(pass), role, color, created:new Date().toISOString().split('T')[0] });
  saveUsers(users);
  ['nu-name','nu-user','nu-pass'].forEach(id=>document.getElementById(id).value='');
  renderUserMgmt();
  alert('✅ ເພີ່ມ User "' + name + '" ສຳເລັດ!');
}

function openEditUser(idx) {
  const users = loadUsers();
  const u = users[idx];
  document.getElementById('eu-idx').value = idx;
  document.getElementById('eu-name').value = u.name;
  document.getElementById('eu-user').value = u.username;
  document.getElementById('eu-pass').value = '';
  document.getElementById('eu-role').value = u.role;
  document.getElementById('eu-color').value = u.color;
  document.getElementById('editUserModal').classList.add('open');
}

function saveEditUser() {
  const idx = parseInt(document.getElementById('eu-idx').value);
  const users = loadUsers();
  const name = document.getElementById('eu-name').value.trim();
  const username = document.getElementById('eu-user').value.trim().toLowerCase();
  const pass = document.getElementById('eu-pass').value;
  const role = document.getElementById('eu-role').value;
  const color = document.getElementById('eu-color').value;
  if(!name||!username){ alert('ກະລຸນາໃສ່ຊ່ື ແລະ Username'); return; }
  // check duplicate username (excluding self)
  if(users.find((x,i)=>i!==idx&&x.username===username)){ alert('Username ນີ້ຖືກໃຊ້ແລ້ວ'); return; }
  users[idx].name = name;
  users[idx].username = username;
  users[idx].role = role;
  users[idx].color = color;
  if(pass.length>=6) users[idx].pwdHash = hashPwd(pass);
  else if(pass.length>0) { alert('Password ໃໝ່ຕ້ອງຢ່າງໜ້ອຍ 6 ຕົວ (ຫຼືຫວ່າງ = ບໍ່ປ່ຽນ)'); return; }
  // if editing current user, refresh session
  if(currentUser && currentUser.username === users[idx].username) {
    currentUser = users[idx];
    updateTopbarUser();
  }
  saveUsers(users);
  document.getElementById('editUserModal').classList.remove('open');
  renderUserMgmt();
  alert('✅ ອັບເດດ User ສຳເລັດ');
}

function deleteUser(idx) {
  const users = loadUsers();
  if(!confirm('ລຶບ User "' + users[idx].name + '"?\nການດຳເນີນການນີ້ບໍ່ສາມາດຍ້ອນຄືນໄດ້')) return;
  users.splice(idx,1);
  saveUsers(users);
  renderUserMgmt();
}

