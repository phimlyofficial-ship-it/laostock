const USERS_KEY = 'velacafe_users_v1';
const SESSION_KEY = 'velacafe_session_v1';

// Simple hash (for demo — not cryptographic)
function hashPwd(s) {
  let h = 0;
  for(let i=0;i<s.length;i++){h=Math.imul(31,h)+s.charCodeAt(i)|0;}
  return 'h' + Math.abs(h).toString(36);
}

function defaultUsers() {
  return [
    { name:'Admin', username:'admin', pwdHash:hashPwd('vela2026'), role:'admin', color:'#c8a96e,#0f0f11', created:'2026-05-01' },
    { name:'Sis Leena', username:'leena', pwdHash:hashPwd('leena2026'), role:'viewer', color:'#3ecfb0,#0f0f11', created:'2026-05-19' },
    { name:'Sis Kitar', username:'kitar', pwdHash:hashPwd('kitar2026'), role:'viewer', color:'#9b5ae0,#0f0f11', created:'2026-05-19' },
  ];
}

function loadUsers() {
  try { const d = localStorage.getItem(USERS_KEY); return d ? JSON.parse(d) : defaultUsers(); }
  catch(e) { return defaultUsers(); }
}
function saveUsers(users) { localStorage.setItem(USERS_KEY, JSON.stringify(users)); }

let currentUser = null;

function doLogin() {
  const u = document.getElementById('loginUser').value.trim();
  const p = document.getElementById('loginPass').value;
  const err = document.getElementById('loginErr');
  err.style.display = 'none';
  if(!u || !p) { err.textContent = '❌ ກະລຸນາໃສ່ Username ແລະ Password'; err.style.display='block'; return; }
  const users = loadUsers();
  const found = users.find(x => x.username === u && x.pwdHash === hashPwd(p));
  if(!found) { err.style.display='block'; err.textContent='❌ Username ຫຼື Password ບໍ່ຖືກ'; document.getElementById('loginPass').value=''; return; }
  currentUser = found;
  localStorage.setItem(SESSION_KEY, JSON.stringify({username: found.username}));
  startApp();
}

function tryAutoLogin() {
  try {
    const s = localStorage.getItem(SESSION_KEY);
    if(!s) return false;
    const sess = JSON.parse(s);
    const users = loadUsers();
    const found = users.find(x => x.username === sess.username);
    if(!found) return false;
    currentUser = found;
    return true;
  } catch(e) { return false; }
}

function doLogout() {
  localStorage.removeItem(SESSION_KEY);
  currentUser = null;
  document.getElementById('appShell').style.display = 'none';
  document.getElementById('loginScreen').style.display = 'flex';
  document.getElementById('loginUser').value = '';
  document.getElementById('loginPass').value = '';
  closeUserMenu();
}

