<!DOCTYPE html>
<html lang="lo">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vela Cafe — ລະບົບການເງິນ</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Lao:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0f0f11;--bg2:#16161a;--bg3:#1e1e24;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.12);
  --text:#f0eff4;--text2:#8a8a9a;
  --accent:#c8a96e;--accent2:#e8c88a;
  --teal:#3ecfb0;--red:#e05a5a;--blue:#5a9be0;--purple:#9b5ae0;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Noto Sans Lao',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;line-height:1.6;}

.topbar{background:var(--bg2);border-bottom:.5px solid var(--border2);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:60px;position:sticky;top:0;z-index:200;}
.logo{font-size:18px;font-weight:700;color:var(--accent);display:flex;align-items:center;gap:10px;}
.logo-icon{width:32px;height:32px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;color:#0f0f11;font-weight:900;}
.topbar-right{display:flex;align-items:center;gap:1rem;}
.gs-btn{background:rgba(66,133,244,.12);border:.5px solid rgba(66,133,244,.3);color:#7aabff;padding:7px 16px;border-radius:8px;font-family:'Noto Sans Lao',sans-serif;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:7px;transition:all .2s;text-decoration:none;}
.gs-btn:hover{background:rgba(66,133,244,.22);}
.last-update{font-size:12px;color:var(--text2);}
.status-dot{width:7px;height:7px;background:var(--teal);border-radius:50%;display:inline-block;margin-right:6px;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

nav{background:var(--bg2);border-bottom:.5px solid var(--border);display:flex;gap:0;padding:0 2rem;overflow-x:auto;}
.nav-tab{padding:14px 20px;font-size:13px;font-weight:500;color:var(--text2);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s;font-family:'Noto Sans Lao',sans-serif;}
.nav-tab:hover{color:var(--text);}
.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent);}

main{padding:2rem;max-width:1400px;margin:0 auto;}
.section{display:none;}.section.active{display:block;}

.setup-panel{background:var(--bg3);border:.5px solid var(--border2);border-radius:12px;padding:1.5rem;margin-bottom:2rem;}
.setup-title{font-size:13px;font-weight:600;color:var(--text2);margin-bottom:1rem;letter-spacing:.06em;text-transform:uppercase;}
.input-row{display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;}
.input-group{display:flex;flex-direction:column;gap:6px;flex:1;min-width:260px;}
.input-group label{font-size:12px;color:var(--text2);}
.input-group input,.input-group select{background:var(--bg2);border:.5px solid var(--border2);border-radius:8px;padding:10px 14px;color:var(--text);font-family:'IBM Plex Mono',monospace;font-size:13px;outline:none;transition:border .2s;}
.input-group input:focus{border-color:var(--accent);}
.btn-load{background:var(--accent);color:#0f0f11;border:none;border-radius:8px;padding:10px 24px;font-family:'Noto Sans Lao',sans-serif;font-weight:700;font-size:13px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.btn-load:hover{background:var(--accent2);}
.btn-load:disabled{opacity:.5;cursor:not-allowed;}

.instructions{background:rgba(200,169,110,.08);border:.5px solid rgba(200,169,110,.2);border-radius:10px;padding:1.25rem 1.5rem;margin-top:1rem;font-size:13px;color:var(--text2);line-height:1.8;}
.instructions strong{color:var(--accent);}
.instructions ol{padding-left:1.2rem;margin-top:.5rem;}
.instructions li{margin-bottom:4px;}
code{background:var(--bg);border:.5px solid var(--border2);padding:2px 8px;border-radius:4px;font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--accent2);}

.metric-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:2rem;}
.metric-card{background:var(--bg2);border:.5px solid var(--border);border-radius:12px;padding:1.2rem 1.4rem;position:relative;overflow:hidden;}
.metric-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.metric-card.gold::before{background:var(--accent);}
.metric-card.teal::before{background:var(--teal);}
.metric-card.red::before{background:var(--red);}
.metric-card.blue::before{background:var(--blue);}
.metric-card.purple::before{background:var(--purple);}
.metric-label{font-size:11px;color:var(--text2);font-weight:500;letter-spacing:.04em;margin-bottom:8px;text-transform:uppercase;}
.metric-value{font-size:22px;font-weight:700;font-family:'IBM Plex Mono',monospace;}
.metric-sub{font-size:11px;color:var(--text2);margin-top:4px;}

.table-card{background:var(--bg2);border:.5px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.5rem;}
.table-header{padding:1rem 1.4rem;display:flex;align-items:center;justify-content:space-between;border-bottom:.5px solid var(--border);}
.table-title{font-size:14px;font-weight:600;color:var(--text);}
.table-badge{font-size:11px;background:var(--bg3);border:.5px solid var(--border2);padding:3px 10px;border-radius:20px;color:var(--text2);}
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th{background:var(--bg3);padding:10px 14px;text-align:left;font-weight:600;font-size:11px;color:var(--text2);letter-spacing:.04em;text-transform:uppercase;white-space:nowrap;}
td{padding:11px 14px;border-top:.5px solid var(--border);color:var(--text);vertical-align:middle;}
tr:hover td{background:rgba(255,255,255,.02);}
.mono{font-family:'IBM Plex Mono',monospace;}
.text-right{text-align:right;}
.amount-pos{color:var(--teal);}
.amount-neg{color:var(--red);}
.badge{display:inline-block;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600;}
.badge-teal{background:rgba(62,207,176,.12);color:var(--teal);}
.badge-red{background:rgba(224,90,90,.12);color:var(--red);}
.badge-blue{background:rgba(90,155,224,.12);color:var(--blue);}
.badge-gold{background:rgba(200,169,110,.12);color:var(--accent);}
.badge-purple{background:rgba(155,90,224,.12);color:var(--purple);}

.sec-header{margin-bottom:1.5rem;}
.sec-title{font-size:18px;font-weight:700;color:var(--text);margin-bottom:4px;}
.sec-sub{font-size:13px;color:var(--text2);}

.no-data{color:var(--text2);font-style:italic;padding:2rem;text-align:center;}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
@media(max-width:900px){.two-col{grid-template-columns:1fr;}}

.equity-card{background:var(--bg2);border:.5px solid var(--border);border-radius:12px;padding:1.4rem;}
.equity-name{font-size:15px;font-weight:700;margin-bottom:1rem;color:var(--accent);}
.equity-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:.5px solid var(--border);font-size:13px;}
.equity-row:last-child{border-bottom:none;}
.equity-total{font-weight:700;color:var(--teal);font-family:'IBM Plex Mono',monospace;}

.chart-card{background:var(--bg2);border:.5px solid var(--border);border-radius:12px;padding:1.4rem;margin-bottom:1.5rem;}
.chart-title{font-size:14px;font-weight:600;margin-bottom:1rem;}
.bar-chart{display:flex;flex-direction:column;gap:10px;}
.bar-row{display:flex;align-items:center;gap:12px;}
.bar-label{font-size:12px;color:var(--text2);width:160px;flex-shrink:0;text-overflow:ellipsis;overflow:hidden;white-space:nowrap;}
.bar-track{flex:1;height:20px;background:var(--bg3);border-radius:4px;overflow:hidden;}
.bar-fill{height:100%;border-radius:4px;transition:width .5s ease;}
.bar-amount{font-size:12px;font-family:'IBM Plex Mono',monospace;color:var(--text2);width:100px;text-align:right;flex-shrink:0;}

.cny-balance{display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;}
.cny-box{flex:1;min-width:140px;background:var(--bg2);border:.5px solid var(--border);border-radius:10px;padding:1rem 1.2rem;}
.cny-label{font-size:11px;color:var(--text2);margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em;}
.cny-val{font-size:20px;font-weight:700;font-family:'IBM Plex Mono',monospace;}

/* ======== SLIP SYSTEM ======== */
.slip-btn{background:rgba(200,169,110,.12);border:.5px solid rgba(200,169,110,.3);color:var(--accent);padding:5px 12px;border-radius:6px;font-family:'Noto Sans Lao',sans-serif;font-size:12px;cursor:pointer;display:inline-flex;align-items:center;gap:5px;transition:all .2s;white-space:nowrap;}
.slip-btn:hover{background:rgba(200,169,110,.22);}
.slip-btn svg{width:13px;height:13px;flex-shrink:0;}
.slip-count{background:var(--accent);color:#0f0f11;border-radius:10px;padding:1px 6px;font-size:10px;font-weight:700;}

/* Modal overlay */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1000;display:none;align-items:center;justify-content:center;padding:1rem;}
.modal-overlay.open{display:flex;}
.modal{background:var(--bg2);border:.5px solid var(--border2);border-radius:16px;width:100%;max-width:640px;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;}
.modal-head{padding:1.2rem 1.4rem;border-bottom:.5px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.modal-head-title{font-size:15px;font-weight:700;}
.modal-close{background:none;border:none;color:var(--text2);cursor:pointer;font-size:20px;line-height:1;padding:4px 8px;border-radius:6px;transition:all .2s;}
.modal-close:hover{background:var(--bg3);color:var(--text);}
.modal-body{padding:1.4rem;overflow-y:auto;flex:1;}
.modal-ref{font-size:12px;color:var(--text2);margin-bottom:1rem;padding:.6rem 1rem;background:var(--bg3);border-radius:8px;}

/* Upload zone */
.upload-zone{border:1.5px dashed var(--border2);border-radius:12px;padding:2rem;text-align:center;cursor:pointer;transition:all .2s;position:relative;margin-bottom:1.2rem;}
.upload-zone:hover,.upload-zone.drag{border-color:var(--accent);background:rgba(200,169,110,.05);}
.upload-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.upload-icon{font-size:32px;margin-bottom:.5rem;}
.upload-text{color:var(--text2);font-size:13px;}
.upload-text strong{color:var(--accent);}

/* Slip grid */
.slip-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;}
.slip-thumb{position:relative;aspect-ratio:3/4;background:var(--bg3);border-radius:8px;overflow:hidden;border:.5px solid var(--border);cursor:pointer;group:true;}
.slip-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .2s;}
.slip-thumb:hover img{transform:scale(1.04);}
.slip-thumb-del{position:absolute;top:6px;right:6px;background:rgba(224,90,90,.85);border:none;border-radius:50%;width:22px;height:22px;color:#fff;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;}
.slip-thumb:hover .slip-thumb-del{opacity:1;}
.slip-thumb-label{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,.7));padding:.4rem .5rem;font-size:10px;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

/* Lightbox */
.lightbox{position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:2000;display:none;align-items:center;justify-content:center;flex-direction:column;}
.lightbox.open{display:flex;}
.lightbox img{max-width:90vw;max-height:80vh;object-fit:contain;border-radius:8px;}
.lightbox-close{position:absolute;top:1.5rem;right:1.5rem;background:rgba(255,255,255,.1);border:none;color:#fff;font-size:22px;width:40px;height:40px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.lightbox-caption{color:rgba(255,255,255,.6);font-size:13px;margin-top:.8rem;}

/* Slip tab */
.slip-section-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:14px;}
.slip-card{background:var(--bg2);border:.5px solid var(--border);border-radius:10px;overflow:hidden;cursor:pointer;transition:border-color .2s;}
.slip-card:hover{border-color:var(--accent);}
.slip-card-img{width:100%;aspect-ratio:3/4;object-fit:cover;background:var(--bg3);}
.slip-card-body{padding:.7rem .9rem;}
.slip-card-ref{font-size:12px;font-weight:600;color:var(--text);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.slip-card-date{font-size:11px;color:var(--text2);}
.slip-card-amount{font-size:13px;font-weight:700;font-family:'IBM Plex Mono',monospace;color:var(--red);margin-top:4px;}
.slip-card-cat{margin-top:4px;}
.slip-empty{text-align:center;padding:3rem;color:var(--text2);grid-column:1/-1;}
.slip-empty-icon{font-size:40px;margin-bottom:1rem;}

.slip-tab-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem;}
.slip-search{background:var(--bg2);border:.5px solid var(--border2);border-radius:8px;padding:9px 14px;color:var(--text);font-family:'Noto Sans Lao',sans-serif;font-size:13px;outline:none;width:260px;transition:border .2s;}
.slip-search:focus{border-color:var(--accent);}

/* ======== STOCK GRID ======== */
.stock-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;flex-wrap:wrap;gap:1rem;}
.stock-view-toggle{display:flex;background:var(--bg3);border:.5px solid var(--border);border-radius:8px;overflow:hidden;}
.stv-btn{background:none;border:none;color:var(--text2);padding:7px 14px;font-family:'Noto Sans Lao',sans-serif;font-size:12px;cursor:pointer;transition:all .2s;}
.stv-btn.active{background:var(--bg2);color:var(--text);border:.5px solid var(--border2);}
.gs-img-hint{background:rgba(200,169,110,.07);border:.5px solid rgba(200,169,110,.18);border-radius:10px;padding:.9rem 1.2rem;font-size:12px;color:var(--text2);margin-bottom:1.5rem;line-height:1.9;}
.stock-product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;}
.prod-card{background:var(--bg2);border:.5px solid var(--border);border-radius:14px;overflow:hidden;cursor:pointer;transition:border-color .25s,transform .2s;position:relative;}
.prod-card:hover{border-color:var(--accent);transform:translateY(-2px);}
.prod-img-wrap{width:100%;aspect-ratio:1/1;background:var(--bg3);position:relative;overflow:hidden;}
.prod-img{width:100%;height:100%;object-fit:cover;transition:transform .3s;}
.prod-card:hover .prod-img{transform:scale(1.06);}
.prod-img-placeholder{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--text2);}
.prod-img-placeholder span{font-size:36px;}
.prod-img-placeholder small{font-size:11px;}
.prod-img-badge{position:absolute;top:8px;right:8px;background:rgba(200,169,110,.9);color:#0f0f11;font-size:10px;font-weight:700;padding:3px 8px;border-radius:20px;}
.prod-edit-overlay{position:absolute;inset:0;background:rgba(0,0,0,.55);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;}
.prod-card:hover .prod-edit-overlay{opacity:1;}
.prod-edit-icon{background:rgba(200,169,110,.9);color:#0f0f11;border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;}
.prod-body{padding:.9rem 1rem 1rem;}
.prod-name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:4px;}
.prod-cat{margin-bottom:6px;}
.prod-meta{font-size:12px;color:var(--text2);display:flex;justify-content:space-between;align-items:center;}
.prod-price{font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:600;color:var(--accent);}
.prod-qty{font-size:12px;color:var(--text2);}

/* list view thumb */
.list-thumb{width:40px;height:40px;border-radius:6px;object-fit:cover;background:var(--bg3);border:.5px solid var(--border);cursor:pointer;}
.list-thumb-placeholder{width:40px;height:40px;border-radius:6px;background:var(--bg3);border:.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;}

/* ======== LOGIN SCREEN ======== */
#loginScreen{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;align-items:center;justify-content:center;padding:1.5rem;}
.login-box{width:100%;max-width:400px;}
.login-logo{text-align:center;margin-bottom:2.5rem;}
.login-logo-icon{width:64px;height:64px;background:var(--accent);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:32px;color:#0f0f11;font-weight:900;margin:0 auto 1rem;}
.login-logo h1{font-size:24px;font-weight:700;color:var(--text);}
.login-logo p{font-size:13px;color:var(--text2);margin-top:4px;}
.login-card{background:var(--bg2);border:.5px solid var(--border2);border-radius:16px;padding:2rem;}
.login-field{display:flex;flex-direction:column;gap:6px;margin-bottom:1.2rem;}
.login-field label{font-size:12px;color:var(--text2);font-weight:500;letter-spacing:.04em;}
.login-field input{background:var(--bg3);border:.5px solid var(--border2);border-radius:10px;padding:12px 14px;color:var(--text);font-family:'Noto Sans Lao',sans-serif;font-size:14px;outline:none;transition:border .2s;width:100%;}
.login-field input:focus{border-color:var(--accent);}
.login-btn{width:100%;background:var(--accent);color:#0f0f11;border:none;border-radius:10px;padding:13px;font-family:'Noto Sans Lao',sans-serif;font-weight:700;font-size:15px;cursor:pointer;margin-top:.5rem;transition:all .2s;}
.login-btn:hover{background:var(--accent2);}
.login-err{background:rgba(224,90,90,.12);border:.5px solid rgba(224,90,90,.3);color:var(--red);border-radius:8px;padding:.7rem 1rem;font-size:13px;margin-bottom:1rem;display:none;text-align:center;}
.login-hint{font-size:11px;color:var(--text2);text-align:center;margin-top:1rem;line-height:1.7;}

/* ======== USER BADGE (topbar) ======== */
.user-badge{display:flex;align-items:center;gap:8px;background:var(--bg3);border:.5px solid var(--border2);border-radius:20px;padding:5px 12px 5px 6px;cursor:pointer;position:relative;transition:border .2s;}
.user-badge:hover{border-color:var(--border2);}
.user-avatar{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;}
.user-name{font-size:12px;font-weight:500;}
.user-role-tag{font-size:10px;padding:1px 7px;border-radius:10px;font-weight:600;}
.role-admin{background:rgba(200,169,110,.15);color:var(--accent);}
.role-viewer{background:rgba(90,155,224,.15);color:var(--blue);}

/* user dropdown */
.user-dropdown{position:absolute;top:calc(100% + 10px);right:0;background:var(--bg2);border:.5px solid var(--border2);border-radius:12px;padding:.5rem;min-width:200px;box-shadow:0 8px 32px rgba(0,0,0,.4);z-index:500;display:none;}
.user-badge.open .user-dropdown{display:block;}
.ud-header{padding:.6rem .8rem 1rem;border-bottom:.5px solid var(--border);margin-bottom:.4rem;}
.ud-name{font-weight:700;font-size:14px;}
.ud-info{font-size:11px;color:var(--text2);margin-top:2px;}
.ud-item{display:flex;align-items:center;gap:10px;padding:.6rem .8rem;border-radius:8px;cursor:pointer;font-size:13px;color:var(--text2);transition:all .2s;}
.ud-item:hover{background:var(--bg3);color:var(--text);}
.ud-item svg{width:15px;height:15px;flex-shrink:0;}
.ud-sep{height:.5px;background:var(--border);margin:.4rem 0;}
.ud-logout{color:var(--red)!important;}

/* ======== USER MANAGEMENT TAB ======== */
.user-mgmt-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;margin-bottom:2rem;}
.user-card{background:var(--bg2);border:.5px solid var(--border);border-radius:14px;padding:1.4rem;}
.uc-top{display:flex;align-items:center;gap:12px;margin-bottom:1rem;}
.uc-avatar{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;flex-shrink:0;}
.uc-info{flex:1;}
.uc-name{font-size:15px;font-weight:700;}
.uc-username{font-size:12px;color:var(--text2);font-family:'IBM Plex Mono',monospace;}
.uc-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-top:.5px solid var(--border);font-size:12px;}
.uc-actions{display:flex;gap:8px;margin-top:1rem;}
.uc-btn{flex:1;padding:7px 0;border-radius:8px;font-family:'Noto Sans Lao',sans-serif;font-size:12px;font-weight:600;cursor:pointer;border:none;transition:all .2s;}
.uc-btn-edit{background:rgba(200,169,110,.12);color:var(--accent);}
